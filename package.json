{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-auto-working",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Pure TUI plugin that keeps OpenCode sessions autonomously progressing.",
  "main": "./dist/index.js",
  "engines": {
    "opencode": "^1.3.7"
  },
  "oc-plugin": ["tui"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sharl210/opencode-auto-working.git"
  },
  "homepage": "https://github.com/Sharl210/opencode-auto-working",
  "bugs": {
    "url": "https://github.com/Sharl210/opencode-auto-working/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run ./script/build.ts",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "prepack": "bun run build",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.3.7",
    "@opencode-ai/sdk": "1.3.7",
    "solid-js": "1.9.11"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.1.92",
    "@opentui/solid": ">=0.1.92"
  },
  "devDependencies": {
    "@opentui/core": "0.1.92",
    "@opentui/solid": "0.1.92",
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.11",
    "@types/node": "22.13.9",
    "typescript": "5.8.2"
  }
}
